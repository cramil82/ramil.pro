# Cache largo para assets estáticos (tienen hash en el nombre)
<FilesMatch "\.(css|js|woff2|woff|png|jpg|jpeg|gif|svg|ico|webp)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Sin caché para HTML — siempre versión fresca
<FilesMatch "\.html$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</FilesMatch>
